<% layout('layouts/boilerplate') -%>

<style>
  #filter-bar {
    display: flex;
    align-items: center;
    overflow-x: auto;
    white-space: nowrap;
    padding: 20px 0;
    margin-bottom: 2rem;
    scrollbar-width: none; /* Firefox */
  }

  #filter-bar::-webkit-scrollbar {
    display: none; /* Safari/Chrome */
  }

  .filter-options {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .filter {
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.2s ease, transform 0.2s ease;
    cursor: pointer;
    min-width: fit-content;
  }

  .filter:hover {
    opacity: 1;
    border-bottom: 2px solid var(--border-light);
  }

  .filter i {
    font-size: 1.5rem;
    margin-bottom: 8px;
  }

  .filter p {
    font-size: 0.75rem;
    font-weight: 500;
    margin: 0;
  }

  .tax-toggle-container {
    border: 1px solid var(--border-light);
    border-radius: 12px;
    height: 3rem;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    margin-left: auto;
    font-size: 0.75rem;
    font-weight: 600;
    background: white;
    cursor: pointer;
  }

  .tax-toggle-container:hover {
    background-color: var(--bg-light);
  }

  .form-check-input:checked {
    background-color: var(--text-main);
    border-color: var(--text-main);
  }

  @media (max-width: 991px) {
    .tax-toggle-container {
      margin-left: 0;
      margin-top: 1rem;
      width: 100%;
    }
    #filter-bar {
        flex-wrap: wrap;
    }
  }
</style>

<div class="container mt-3">
  <!-- Filter bar -->
  <div id="filter-bar">
    <div class="filter-options">
        <div class="filter">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-bed"></i>
            <p>Rooms</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-mountain-city"></i>
            <p>Iconic cities</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </div>
        <div class="filter">
            <i class="fa-brands fa-fort-awesome"></i>
            <p>Castles</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-person-swimming"></i>
            <p>Amazing pools</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-campground"></i>
            <p>Camping</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-cow"></i>
            <p>Farms</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-snowflake"></i>
            <p>Arctic</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-igloo"></i>
            <p>Domes</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-sailboat"></i>
            <p>Boats</p>
        </div>
    </div>
    
    <div class="tax-toggle-container">
      <div class="form-check form-switch form-check-reverse">
        <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
        <label class="form-check-label" for="flexSwitchCheckDefault">Display total before taxes</label>
      </div>
    </div>
  </div>

  <!-- Listings Grid -->
  <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1">
    <% for( let listing of allListings){ %>
      <div class="col">
        <a href="/listing/<%= listing._id %>">
            <div class="card h-100">
              <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h5 class="card-title"><%= listing.location %>, <%= listing.country %></h5>
                    <div class="rating d-flex align-items-center">
                        <i class="fa-solid fa-star me-1 small"></i>
                        <span class="small font-weight-normal">New</span>
                    </div>
                </div>
                <p class="card-text"><%= listing.title %></p>
                <p class="card-text text-muted mb-1">Feb 15 - 20</p>
                <div class="price-container">
                  &#8377;<%= listing.price.toLocaleString("en-IN") %> <span>night</span>
                  <i class="tax-info small">&nbsp; &nbsp; +18%GST</i>
                </div>
              </div>
            </div>
          </a>
      </div>
      <% } %>
  </div>
</div>

<script>
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");
  let taxInfo = document.getElementsByClassName("tax-info");
  taxSwitch.addEventListener("click", () => {
    for (info of taxInfo) {
      if (info.style.display != "inline") {
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  })
</script>
